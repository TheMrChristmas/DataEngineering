#!/usr/bin/env bash
set -euo pipefail

start_desktop_context() {
  if command -v flatpak-spawn >/dev/null 2>&1; then
    flatpak-spawn --host systemctl --user start docker-desktop >/dev/null 2>&1 || return 1
    exec flatpak-spawn --host --env=DOCKER_CONTEXT=desktop-linux docker "$@"
  fi

  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user start docker-desktop >/dev/null 2>&1 || return 1
    if [[ -x /usr/bin/docker ]]; then
      DOCKER_CONTEXT=desktop-linux exec /usr/bin/docker "$@"
    fi
    if [[ -x /usr/local/bin/docker ]]; then
      DOCKER_CONTEXT=desktop-linux exec /usr/local/bin/docker "$@"
    fi
  fi

  return 1
}

if start_desktop_context "$@"; then
  exit 0
fi

if command -v flatpak-spawn >/dev/null 2>&1; then
  exec flatpak-spawn \
    --host \
    --env=DOCKER_CONTEXT=default \
    --env=DOCKER_HOST=unix:///var/run/docker.sock \
    docker "$@"
fi

if [[ -x /usr/bin/docker ]]; then
  DOCKER_CONTEXT=default DOCKER_HOST=unix:///var/run/docker.sock exec /usr/bin/docker "$@"
fi

if [[ -x /usr/local/bin/docker ]]; then
  DOCKER_CONTEXT=default DOCKER_HOST=unix:///var/run/docker.sock exec /usr/local/bin/docker "$@"
fi

printf 'docker is not available in this environment.\n' >&2
exit 127